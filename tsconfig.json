{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2020", "dom"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@config/*":    ["src/config/*"],
      "@constants/*": ["src/constants/*"],
      "@types-local/*": ["src/types/*"],
      "@utils/*":     ["src/utils/*"],
      "@services/*":  ["src/services/*"],
      "@pages/*":     ["src/pages/*"],
      "@flows/*":     ["src/flows/*"],
      "@fixtures/*":  ["src/fixtures/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist", "allure-report"]
}
